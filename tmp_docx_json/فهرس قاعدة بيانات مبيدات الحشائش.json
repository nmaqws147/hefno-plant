  "use_cases": {
    "search_by_herbicide": "items.find(a => a.id === 'hai-036')  // جلايفوسات",
    "search_by_weed": "relationships.filter(r => r.weed_id === 'weed-01').sort((a,b) => b.efficacy_level - a.efficacy_level)",
    "pre_emergence_only": "items.filter(a => a.application.dose_pre_emergence_ar && !a.application.dose_post_emergence_ar)",
    "post_emergence_only": "items.filter(a => a.application.dose_post_emergence_ar && !a.application.dose_pre_emergence_ar)",
    "grass_herbicides": "items.filter(a => a.hrac_group_id === 'hrac-a')  // ACCase — نجيليات فقط",
    "broadleaf_herbicides": "items.filter(a => a.hrac_group_id === 'hrac-o')  // أوكسين — عريضات فقط",
    "non_selective": "items.filter(a => a.hrac_group_id === 'hrac-g' || a.hrac_group_id === 'hrac-d')",
    "rotation_program": "programs.find(p => p.crop.includes('قمح'))",
    "resistance_warning": "ai.resistance.risk_level >= 4",
    "safe_rotation": "groups.find(g => g.id === ai.hrac_group_id).rotation_compatible_ids"
  },
