  "use_cases": {
    "search_by_ai": "items.find(a => a.id === 'iai-032')  // أبامكتين",
    "search_by_pest": "relationships.filter(r => r.pest_id === 'pest-12').sort((a,b) => b.efficacy_level - a.efficacy_level)",
    "resistance_warning": "ai.resistance.risk_level >= 4  // بيريثرويدات ونيونيكوتينويدات",
    "safe_rotation": "groups.find(g => g.id === ai.irac_group_id).rotation_compatible_ids",
    "rotation_program": "programs.find(p => p.crop === 'طماطم')",
    "acaricides_only": "items.filter(a => a.target_pests.some(p => p.id.startsWith('pest-2')))",
    "bio_safe": "items.filter(a => a.resistance.risk_level === 1)",
    "organic_allowed": "items.filter(a => a.irac_group_id === 'irac-11a' || a.irac_group_id === 'irac-un')",
    "cross_resistance": "ai.resistance.cross_resistance_groups"
  },
