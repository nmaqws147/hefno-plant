[
 {
      "id": "nema-1",
      "name_ar": "نيماتودا تعقد الجذور (Root-Knot Nematode)",
      "scientificName": "Meloidogyne incognita (Kofoid & White) Chitwood / Meloidogyne javanica (Treub) Chitwood / Meloidogyne arenaria (Neal) Chitwood",
      "family_ar": "ميلويدوجينيداي — Meloidogynidae",
      "family_en": "Meloidogynidae",
      "severity": "very high",
      "type": "نيماتودا ثابتة داخلية — تُصيب الجذور وتُسبب تعقدات مميزة",
      "fullDescription": "أكثر نيماتودا النبات خطورةً وانتشارًا في العالم. تُسبب تعقدات (Galls) مميزة على الجذور بسهولة التعرف عليها. تُصيب أكثر من 2000 نوع نباتي. في مصر تُعد M. incognita وM. javanica الأكثر شيوعًا وخطورةً. الإناث الثابتة داخل جذور تضع 200-1000 بيضة في كيس بيض جيلاتيني. تُخسر المحاصيل المصرية ما يُقدَّر بـ 15-30% سنويًا في الأراضي الملوثة.",
      "symptoms": [
        "تعقدات (Galls/Knots) كروية-غير منتظمة على الجذور — العرض التشخيصي الحاسم",
        "تضخم الجذور الرئيسية والثانوية مع تشوهها",
        "ذبول وتقزم النباتات وضعف نموها رغم توافر الماء والغذاء",
        "اصفرار الأوراق السفلية مشابه لنقص الحديد أو الآزوت",
        "انخفاض حاد في الإنتاج وضعف جودة الثمار",
        "بقع دائرية في الحقل حيث النباتات ضعيفة النمو",
        "تحلل الجذور المتعقدة ودخول الفطريات والبكتيريا"
      ],
      "infectionCycle": "اليرقات J2 تفقس من البيض وتنتقل في التربة للجذور الفتية. تخترق القشرة وتُحفّز تكوين خلايا عملاقة (Giant Cells) بجوارها للتغذية. الأنثى تتحول لكيسة كمثرية ثابتة وتضع البيض. دورة الحياة 25-30 يومًا عند 25°م.",
      "favorableConditions": "تربة رملية خفيفة، درجات حرارة 25-30°م، رطوبة تربة معتدلة، زراعة متكررة للعوائل",
      "hostPlants": [
        "طماطم",
        "فلفل",
        "باذنجان",
        "خيار",
        "كوسة",
        "بطيخ",
        "بطاطس",
        "فول",
        "فاصوليا",
        "بنجر سكري",
        "جزر",
        "خس",
        "بصل",
        "ثوم",
        "2000+ نوع"
      ],
      "economicThreshold": "500 يرقة J2 / 200 جم تربة = تدخل ضروري",
      "naturalEnemies": [
        "Paecilomyces lilacinus — فطر يُصيب بيض Meloidogyne",
        "Pochonia chlamydosporia — فطر يُصيب البيض",
        "Bacillus firmus — بكتيريا ممرضة للنيماتودا",
        "Trichoderma harzianum — يُقلل كثافة النيماتودا",
        "Purpureocillium lilacinum"
      ],
      "management": {
        "cultural": [
          "تعقيم التربة بالشمس (Solarization): نايلون شفاف 4-6 أسابيع صيفًا — يُقلل الكثافة 80-95%",
          "دورة زراعية: إدخال محاصيل غير عائلة (نجيليات، قمح، ذرة) لمدة 2-3 سنوات",
          "زراعة محاصيل طاردة: القطيفة Tagetes spp. تُنتج ثيوفين يقتل Meloidogyne",
          "إضافة مادة عضوية: كمبوست + بقايا نباتية تُشجع أعداء النيماتودا الطبيعية",
          "استخدام أصناف مقاومة تحمل جين Mi (طماطم مقاومة لـ M. incognita)",
          "التطعيم على أسماك مقاومة للنيماتودا في الطماطم والباذنجان"
        ],
        "biological": [
          "Paecilomyces lilacinus (كيس بيض) بمعدل 2-4 كجم/فدان — خلط مع التربة",
          "Bacillus firmus بمعدل 5 كجم/فدان — إضافة قبل الزراعة",
