        "crops_ar": ["خضروات", "بساتين فاكهة"]
      },
      {
        "method_ar": "التشميس الصيفي (Solarization)",
        "details_ar": "تغطية التربة الرطبة بنايلون شفاف 40 ميكرون لمدة 4-8 أسابيع في الصيف — درجة حرارة التربة تصل 55-65°م",
        "effectiveness_ar": "قتل 95-99% من بذور الحشائش السطحية والنيماتودا والأمراض",
        "crops_ar": ["جميع المحاصيل — قبل الزراعة"]
      },
      {
        "method_ar": "الدورة الزراعية",
        "details_ar": "تبديل المحاصيل يكسر دورة حياة الحشائش المتخصصة في محصول معين",
        "effectiveness_ar": "تقليل 40-60% على المدى البعيد",
        "crops_ar": ["جميع المحاصيل"]
      },
      {
        "method_ar": "المحاصيل الكثيفة الخانقة",
        "details_ar": "زراعة محاصيل تُظلل التربة بسرعة (برسيم — شعير كثيف — برسيم حجازي) تُقلل إنبات الحشائش",
        "effectiveness_ar": "تقليل 50-70%",
        "crops_ar": ["دورة مع الخضروات والمحاصيل الحقلية"]
      },
      {
        "method_ar": "العزيق المتقن والمتكرر",
        "details_ar": "العزيق السطحي 2-3 سم أفضل من العميق — لا يُصعّد بذوراً جديدة",
        "effectiveness_ar": "فعّال مع الحشائش الحولية",
        "crops_ar": ["جميع المحاصيل"]
      }
    ]
  },

