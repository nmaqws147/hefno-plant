    ],
    "methods_ar": [
      {
        "method_ar": "المالش العضوي (Mulching)",
        "details_ar": "تغطية التربة بطبقة 5-10 سم من القش أو نشارة الخشب أو أوراق النخيل — تمنع ضوء الشمس عن البذور",
