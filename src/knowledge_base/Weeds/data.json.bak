  "organic_weed_management": {
    "title_ar": "المكافحة العضوية المتكاملة للحشائش",
    "principles_ar": [
      "المنع أهم من العلاج — لا تسمح للحشيشة بالإبذار",
      "المحصول الكثيف السريع هو أفضل مكافح للحشائش",
