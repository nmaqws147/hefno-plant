  "weed_identification_key": {
    "title_ar": "مفتاح تعريف الحشائش الشائعة",
    "steps": [
      {
        "step": 1,
        "question_ar": "هل الساق مثلثة المقطع؟",
        "yes_ar": "← عائلة السعدية (Cyperaceae) — سعد الزراعة أو الحلفا المائية",
        "no_ar": "← انتقل للخطوة 2"
      },
      {
        "step": 2,
        "question_ar": "هل الأوراق رفيعة ضيقة مع عروق موازية؟",
        "yes_ar": "← نجيليات — نجيل شيطان أو فالاريس أو دخن بري",
        "no_ar": "← عريضة الأوراق — انتقل للخطوة 3"
      },
      {
        "step": 3,
        "question_ar": "هل النبات بدون أوراق حقيقية (خيوط ملتوية)؟",
        "yes_ar": "← طفيلي — كشوث (خيوط برتقالية) أو هالوك (يخرج من التربة)",
        "no_ar": "← انتقل للخطوة 4"
      },
      {
        "step": 4,
        "question_ar": "هل النبات لحمي عصاري (ساق سميك مائي)؟",
        "yes_ar": "← الرجلة (Portulaca) — أوراق سميكة خضراء داكنة",
        "no_ar": "← انتقل للخطوة 5"
      },
      {
        "step": 5,
        "question_ar": "هل للنبات أشواك؟",
        "yes_ar": "← عاقول (ثمار شوكية) أو دندر (أوراق شوكية)",
        "no_ar": "← انتقل للخطوة 6"
      },
      {
        "step": 6,
        "question_ar": "هل النبات يتسلق ويلتف؟",
        "yes_ar": "← حلفا (Convolvulus) — أزهار قمعية بيضاء أو وردية",
        "no_ar": "← حميض أو سلق بري أو خردل بري — ابحث عن شكل الورقة والزهرة"
      }
    ]
  },

