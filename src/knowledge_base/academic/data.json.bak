  "essential_equations": {
    "title_ar": "المعادلات الأساسية في التغذية النباتية والزراعة",
    "equations": [
      {
        "id": "eq-001",
        "name_ar": "حساب جرعة السماد من تحليل التربة",
        "name_en": "Fertilizer Dose from Soil Analysis",
        "formula": "Fertilizer dose = (Crop requirement - Soil supply) ÷ Fertilizer efficiency",
        "example_ar": "قمح يحتاج 80 كجم N — التربة توفر 20 كجم — كفاءة اليوريا 50% → (80-20) ÷ 0.5 = 120 كجم N → 120 ÷ 0.46 = 261 كجم يوريا/فدان",
        "variables_ar": {
          "crop_requirement_ar": "احتياج المحصول من العنصر (كجم/فدان)",
          "soil_supply_ar": "ما توفره التربة من نفس العنصر (من تحليل التربة)",
          "efficiency_ar": "كفاءة استخدام السماد (N=50%, P=20%, K=60%)"
        }
      },
      {
        "id": "eq-002",
        "name_ar": "حساب EC المحلول المغذي",
        "name_en": "Nutrient Solution EC Calculation",
        "formula": "EC_total = Σ(concentration_i × EC_factor_i)",
        "example_ar": "يوريا 1 كجم/1000 لتر = EC +0.4 dS/m — نترات كالسيوم 1 كجم/1000 لتر = EC +0.9 dS/m",
        "note_ar": "EC الأمثل للتنقيط: 1.5-3.5 dS/m حسب المحصول والطور"
      },
      {
        "id": "eq-003",
        "name_ar": "معادلة البخر-نتح المرجعية (Penman-Monteith)",
        "name_en": "Reference Evapotranspiration (ET₀)",
        "formula": "ET₀ = [0.408Δ(Rn-G) + γ(900/(T+273))u₂(es-ea)] ÷ [Δ + γ(1+0.34u₂)]",
        "note_ar": "المعادلة الرسمية لـ FAO لحساب احتياجات الري — Rn=الإشعاع الشمسي الصافي — T=درجة الحرارة — u₂=سرعة الرياح — es=ضغط بخار الإشباع — ea=ضغط البخار الفعلي",
        "practical_ar": "ETcrop = ET₀ × Kc — Kc=معامل المحصول (يختلف بحسب طور النمو)"
      },
      {
        "id": "eq-004",
        "name_ar": "قانون فيك للانتشار",
        "name_en": "Fick's First Law of Diffusion",
        "formula": "J = -D × (dC/dx)",
        "note_ar": "J=تدفق المادة — D=معامل الانتشار — dC/dx=تدرج التركيز — يُطبق في انتقال العناصر من التربة لسطح الجذر"
      },
      {
        "id": "eq-005",
        "name_ar": "حساب الإنتاجية المائية للري",
        "name_en": "Water Use Efficiency (WUE)",
        "formula": "WUE = Crop yield (kg) ÷ Water consumed (m³)",
        "example_ar": "قمح 3 طن/فدان ÷ 2000 م³ = 1.5 كجم/م³ — الري بالتنقيط يرفعها لـ 2-3 كجم/م³"
      },
      {
        "id": "eq-006",
        "name_ar": "معادلة التمثيل الضوئي الكاملة",
        "name_en": "Complete Photosynthesis Equation",
        "formula": "6CO₂ + 12H₂O + Light → C₆H₁₂O₆ + 6O₂ + 6H₂O",
        "note_ar": "النبات يستخدم 12 جزيء ماء — ينتج 6 منها مع الأكسجين — و6 تدخل في الجلوكوز"
      },
      {
        "id": "eq-007",
        "name_ar": "حساب الاستحقاق الكيميائي للسماد",
        "name_en": "Chemical Equivalent of Fertilizer",
        "formula": "N in fertilizer (kg) = Weight of fertilizer (kg) × N% ÷ 100",
        "examples_ar": [
          "100 كجم يوريا × 46% = 46 كجم N",
          "100 كجم نترات أمونيوم × 33.5% = 33.5 كجم N",
          "100 كجم MAP × 12% N + 61% P₂O₅ = 12 كجم N + 61 كجم P₂O₅"
        ]
      },
      {
        "id": "eq-008",
        "name_ar": "تحويل P₂O₅ إلى P والعكس",
        "name_en": "P₂O₅ to P Conversion",
        "formula": "P = P₂O₅ × 0.436 || P₂O₅ = P × 2.291",
        "also": "K = K₂O × 0.83 || K₂O = K × 1.205",
        "note_ar": "الأسمدة تُعبر عن P كـ P₂O₅ وعن K كـ K₂O — التربة تُعبر عن P وK مباشرة — انتبه للتحويل"
      }
    ]
  },
