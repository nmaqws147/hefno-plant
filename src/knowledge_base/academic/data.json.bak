            "pages": "4-10"
          }
        ]
      },
      {
        "fert_id": "fert-009",
        "name_ar": "سوبر فوسفات أحادي SSP",
        "name_en": "Single Superphosphate",
        "chemistry": {
          "composition": "Ca(H₂PO₄)₂ + CaSO₄ + H₂O",
          "p2o5_percent": "16-20%",
          "ca_percent": "18-21%",
          "s_percent": "10-12%",
          "production_ar": "تفاعل الفوسفات الصخري مع حمض الكبريتيك: Ca₃(PO₄)₂ + 2H₂SO₄ → Ca(H₂PO₄)₂ + 2CaSO₄"
        },
        "soil_reactions_ar": {
          "in_soil_ar": "Ca(H₂PO₄)₂ يتفاعل مع التربة ويتحول لـ CaHPO₄ ثم Ca₃(PO₄)₂ (يتثبت)",
          "fixation_ar": "تثبيت الفوسفور: يرتبط بـ Fe وAl في التربة الحمضية — وبـ Ca في القلوية — يقلل التوافر",
          "ph_effect_ar": "التوافر أعلى في pH 6-7 — ينخفض بشدة في pH أعلى من 7.5 (التربة المصرية)"
        },
        "improvement_strategies_ar": [
          "خلط مع حمض الهيوميك يُقلل التثبيت",
          "التطبيق بجانب البذرة (Band application) يقلل ملامسة التربة",
          "PSB (بكتيريا محللة الفوسفات) تُحرر الفوسفور المثبت",
          "تحميض التربة يحسن التوافر"
        ],
        "key_references": [
          {
            "authors": "Syers, J.K., Johnston, A.E., & Curtin, D.",
            "year": 2008,
            "title": "Efficiency of soil and fertilizer phosphorus use",
            "publisher": "FAO Fertilizer and Plant Nutrition Bulletin 18",
            "location": "Rome"
          }
        ]
      },
      {
        "fert_id": "fert-027",
        "name_ar": "رايزوبيوم",
        "name_en": "Rhizobium",
        "microbiology": {
          "classification_ar": "بكتيريا — Alphaproteobacteria — رتبة Rhizobiales",
          "genera_ar": [
            "Rhizobium",
            "Bradyrhizobium",
            "Mesorhizobium",
            "Sinorhizobium",
            "Azorhizobium"
          ],
          "nodule_formation_ar": "تكوين العقد: جذر النبات يُفرز فلافونويدات → تُنشط جينات nod في الرايزوبيوم → تكوين عوامل Nod → تطور العقدة",
          "nitrogen_fixation_mechanism_ar": "إنزيم النيتروجيناز (nifH gene): N₂ + 8H⁺ + 8e⁻ + 16ATP → 2NH₃ + H₂ + 16ADP",
          "leghemoglobin_ar": "الليجهيموجلوبين — يُنظم تركيز O₂ داخل العقدة — يحمي النيتروجيناز من الأكسدة — يُعطي لون العقدة الوردي"
        },
        "specificity_ar": {
          "rhizobium_leguminosarum_ar": "فول + بازلاء + عدس + حمص",
          "bradyrhizobium_japonicum_ar": "فول الصويا",
          "mesorhizobium_ciceri_ar": "حمص",
          "rhizobium_phaseoli_ar": "فاصوليا"
        },
        "inoculation_best_practices_ar": [
          "التلقيح مباشرة قبل الزراعة — لا تعريض للشمس",
          "الخلط بمادة لاصقة (سكر أو صمغ عربي) لتثبيته على البذرة",
          "تجنب الخلط مع مبيدات الفطريات",
          "درجة حرارة التخزين 4-8°م"
