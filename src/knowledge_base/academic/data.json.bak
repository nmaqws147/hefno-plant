    "description_ar": "مرجع أكاديمي شامل للطلاب والمهندسين والباحثين — مصطلحات علمية + مراجع موثقة + معادلات + تصنيف نباتي",
    "target_users_ar": [
      "طلاب كليات الزراعة",
      "مهندسون زراعيون",
      "دكاترة وباحثون",
      "شركات زراعية متخصصة"
    ],
    "citation_style": "APA 7th Edition",
    "last_updated": "2024"
  },
  "glossary": {
    "title_ar": "قاموس المصطلحات الزراعية العلمية",
    "title_en": "Agricultural Scientific Glossary",
    "description_ar": "المصطلحات الأساسية في العلوم الزراعية — عربي / إنجليزي / لاتيني مع التعريف الأكاديمي",
    "terms": [
      {
        "id": "term-001",
        "arabic": "التغذية المعدنية للنبات",
        "english": "Mineral Plant Nutrition",
        "latin": null,
        "definition_ar": "علم دراسة العناصر الكيميائية الضرورية لنمو النبات واستيفاء وظائفه الحيوية — يشمل 17 عنصراً أساسياً",
        "definition_en": "The science of chemical elements essential for plant growth and physiological function, encompassing 17 essential elements",
        "related_terms": [
          "العناصر الكبرى",
          "العناصر الصغرى",
          "الامتصاص الأيوني"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-002",
        "arabic": "العناصر الغذائية الكبرى",
        "english": "Macronutrients",
        "latin": null,
        "definition_ar": "العناصر التي يحتاجها النبات بكميات كبيرة نسبياً — تشمل N و P و K و Ca و Mg و S — تُقاس بالكيلوجرامات لكل فدان",
        "definition_en": "Nutrients required by plants in relatively large amounts: N, P, K, Ca, Mg, and S — measured in kg/feddan",
        "related_terms": [
          "النيتروجين",
          "الفوسفور",
          "البوتاسيوم"
        ],
        "field_ar": "تغذية النبات"
      },
      {
        "id": "term-003",
        "arabic": "العناصر الغذائية الصغرى",
        "english": "Micronutrients / Trace Elements",
        "latin": null,
        "definition_ar": "العناصر التي يحتاجها النبات بكميات ضئيلة جداً — تشمل Fe وZn وMn وCu وB وMo وCl وNi — تُقاس بالجزء في المليون (ppm)",
        "definition_en": "Nutrients required in very small amounts: Fe, Zn, Mn, Cu, B, Mo, Cl, and Ni — measured in ppm",
        "related_terms": [
          "الكيلات",
          "التثبيت",
          "نقص العناصر"
        ],
        "field_ar": "تغذية النبات"
      },
      {
        "id": "term-004",
        "arabic": "التمثيل الضوئي",
        "english": "Photosynthesis",
        "latin": "Photosynthesis",
        "definition_ar": "العملية البيوكيميائية التي تحوّل فيها النباتات الخضراء طاقة الضوء + ثاني أكسيد الكربون + الماء إلى جلوكوز وأكسجين",
        "definition_en": "The biochemical process by which green plants convert light energy + CO₂ + H₂O into glucose and oxygen",
        "equation": "6CO₂ + 6H₂O + Light Energy → C₆H₁₂O₆ + 6O₂",
        "related_terms": [
          "الكلوروفيل",
          "دورة كالفن",
          "التنفس الخلوي"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-005",
        "arabic": "التنفس الخلوي",
        "english": "Cellular Respiration",
        "latin": null,
        "definition_ar": "عملية أكسدة المركبات العضوية للحصول على طاقة ATP — تحدث في الميتوكوندريا",
        "definition_en": "The process of oxidizing organic compounds to produce ATP energy — occurs in mitochondria",
        "equation": "C₆H₁₂O₆ + 6O₂ → 6CO₂ + 6H₂O + ATP",
        "related_terms": [
          "التمثيل الضوئي",
          "الميتوكوندريا",
          "ATP"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-006",
        "arabic": "النتح",
        "english": "Transpiration",
        "latin": null,
        "definition_ar": "فقد الماء من النبات على شكل بخار ماء — يحدث أساساً عبر الثغور — يُحرك الماء والعناصر الغذائية من الجذور للأوراق",
        "definition_en": "Water loss from plants as water vapor — occurs mainly through stomata — drives water and nutrients from roots to leaves",
        "formula_ar": "معدل النتح يتأثر بـ: درجة الحرارة + الرطوبة + سرعة الرياح + شدة الإضاءة",
        "related_terms": [
          "الثغور",
          "البخر-نتح",
          "دفق الإكسيلم"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-007",
        "arabic": "الإمتصاص الأيوني",
        "english": "Ion Uptake / Mineral Absorption",
        "latin": null,
        "definition_ar": "عملية امتصاص الأيونات المعدنية من التربة عبر الجذور — يشمل آليتين: الامتصاص السلبي (Passive) والنشط (Active) الذي يحتاج ATP",
        "definition_en": "The process of absorbing mineral ions from soil through roots — includes passive (no energy) and active (ATP-requiring) mechanisms",
        "related_terms": [
          "ناقلات الأيونات",
          "ATP",
          "الضخ البروتوني"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-008",
        "arabic": "التثبيت البيولوجي للنيتروجين",
        "english": "Biological Nitrogen Fixation (BNF)",
        "latin": null,
        "definition_ar": "تحويل نيتروجين الهواء (N₂) إلى أمونيا (NH₃) بواسطة كائنات دقيقة — أهمها الرايزوبيوم المتكافل مع البقوليات",
        "definition_en": "Conversion of atmospheric N₂ to ammonia (NH₃) by microorganisms — most important is Rhizobium symbiotic with legumes",
        "equation": "N₂ + 8H⁺ + 8e⁻ + 16ATP → 2NH₃ + H₂ + 16ADP + 16Pi",
        "enzyme_ar": "إنزيم النيتروجيناز (Nitrogenase) — يتعطل بالأكسجين",
        "related_terms": [
          "رايزوبيوم",
          "العقد الجذرية",
          "النيتروجيناز"
        ],
        "field_ar": "ميكروبيولوجيا التربة"
      },
      {
        "id": "term-009",
        "arabic": "دورة النيتروجين في التربة",
        "english": "Nitrogen Cycle",
        "latin": null,
        "definition_ar": "مسار النيتروجين في النظام البيئي — يشمل: التثبيت → الأمونيا → النترتة → النزع → التثبيت مجدداً",
        "definition_en": "The pathway of nitrogen through the ecosystem: Fixation → Ammonification → Nitrification → Denitrification → Re-fixation",
        "processes_ar": {
          "ammonification_ar": "تحلل البروتين بفعل البكتيريا → NH₄⁺",
          "nitrification_ar": "NH₄⁺ → NO₂⁻ → NO₃⁻ (بواسطة Nitrosomonas و Nitrobacter)",
          "denitrification_ar": "NO₃⁻ → N₂ (في غياب الأكسجين — يُفقد N من التربة)",
          "fixation_ar": "N₂ → NH₃ (بيولوجياً أو كيميائياً)"
        },
        "related_terms": [
          "نترتة",
          "أمونيوم",
          "نترات",
          "نزع النترات"
        ],
        "field_ar": "الكيمياء الزراعية"
      },
      {
        "id": "term-010",
        "arabic": "الأس الهيدروجيني (pH)",
        "english": "pH (Potential of Hydrogen)",
        "latin": null,
        "definition_ar": "مقياس حموضة أو قلوية المحلول — يتراوح من 0 (حمضي جداً) إلى 14 (قلوي جداً) — pH 7 محايد",
        "definition_en": "A measure of the acidity or alkalinity of a solution — ranges from 0 (very acidic) to 14 (very alkaline) — pH 7 is neutral",
        "formula": "pH = -log[H⁺]",
        "agricultural_significance_ar": "يتحكم في توافر العناصر الغذائية — pH 6-7 الأمثل لمعظم المحاصيل — التربة المصرية قلوية (7.5-8.5)",
        "related_terms": [
          "حموضة التربة",
          "قلوية التربة",
          "توافر العناصر"
        ],
        "field_ar": "علم التربة"
      },
      {
        "id": "term-011",
        "arabic": "الطاقة الاستيعابية للتبادل الكاتيوني",
        "english": "Cation Exchange Capacity (CEC)",
        "latin": null,
        "definition_ar": "قدرة التربة على احتجاز وتبادل الكاتيونات الموجبة (Ca²⁺, Mg²⁺, K⁺, Na⁺, H⁺) — تُقاس بالمكافئ المللي / 100 جم تربة",
        "definition_en": "The soil's ability to hold and exchange positively charged cations — measured in meq/100g soil",
        "significance_ar": "CEC عالية = تربة تحتفظ بالأسمدة أكثر — التربة الطينية CEC أعلى من الرملية",
        "typical_values_ar": {
          "sandy_ar": "3-8 meq/100g",
          "loamy_ar": "15-25 meq/100g",
          "clay_ar": "25-50 meq/100g",
          "organic_matter_ar": "100-300 meq/100g"
        },
        "related_terms": [
          "كولويدات التربة",
          "الطين المعدني",
          "المادة العضوية"
        ],
        "field_ar": "علم التربة"
      },
      {
        "id": "term-012",
        "arabic": "الأسمودة / الضغط الأسموزي",
        "english": "Osmosis / Osmotic Pressure",
        "latin": null,
        "definition_ar": "انتقال الماء عبر غشاء شبه نفاذ من محلول أقل تركيزاً إلى أكثر تركيزاً — الضغط الأسموزي العالي في التربة يُصعّب امتصاص النبات للماء",
        "definition_en": "Movement of water through a semipermeable membrane from lower to higher solute concentration — high osmotic pressure in soil inhibits water uptake",
        "agricultural_significance_ar": "الملوحة العالية ترفع الضغط الأسموزي للتربة — النبات يعاني إجهاداً مائياً رغم توفر الماء (الجفاف الفسيولوجي)",
        "related_terms": [
          "الملوحة",
          "الجفاف الفسيولوجي",
          "التركيز المحلولي"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-013",
        "arabic": "معامل الانتشار",
        "english": "Diffusion Coefficient",
        "latin": null,
        "definition_ar": "سرعة انتشار مادة معينة في وسط معين — يتأثر بدرجة الحرارة والتركيز — مهم في انتقال العناصر من التربة للجذور",
        "definition_en": "The rate at which a substance diffuses through a medium — affected by temperature and concentration — important in nutrient movement from soil to roots",
        "formula": "J = -D × (dC/dx) — معادلة فيك للانتشار",
        "related_terms": [
          "الانتقال الجماعي",
          "تدفق الإكسيلم",
          "امتصاص الجذور"
        ],
        "field_ar": "فيزياء التربة"
      },
      {
        "id": "term-014",
        "arabic": "الكفاءة الاقتصادية للسماد",
        "english": "Fertilizer Use Efficiency (FUE)",
        "latin": null,
        "definition_ar": "نسبة العنصر المُمتَص من السماد إلى الكمية المُضافة — عادةً N 30-50% — P 10-25% — K 40-60%",
        "definition_en": "The proportion of applied fertilizer nutrients that are absorbed by the plant — typically N: 30-50%, P: 10-25%, K: 40-60%",
        "formula": "FUE (%) = (Nutrient in plant / Nutrient applied) × 100",
        "improvement_methods_ar": [
          "التسميد التنقيطي يرفع FUE 20-40%",
          "التقسيم على دفعات يقلل الفقد",
          "استخدام المثبطات"
        ],
        "related_terms": [
          "الكفاءة الزراعية",
          "فقد النيتروجين",
          "تثبيت الفوسفور"
        ],
        "field_ar": "علم الأسمدة"
      },
      {
        "id": "term-015",
        "arabic": "العلاقة المتبادلة بين العناصر",
        "english": "Nutrient Antagonism & Synergism",
        "latin": null,
        "definition_ar": "التضاد: زيادة عنصر تُقلل امتصاص آخر (مثل: K الزائد يُقلل Mg). التكافل: زيادة عنصر تُحسن امتصاص آخر (مثل: P يُحسن امتصاص Zn)",
        "definition_en": "Antagonism: excess of one nutrient reduces uptake of another (e.g., high K reduces Mg). Synergism: one nutrient improves uptake of another",
        "examples_ar": {
          "antagonism_examples_ar": [
            "K الزائد ↓ Mg و Ca",
            "Ca الزائد ↓ Mg و K",
            "N الزائد ↓ Cu",
            "P الزائد ↓ Zn و Fe"
          ],
          "synergism_examples_ar": [
            "N يحسن امتصاص P",
            "Mg يحسن امتصاص P (Mg جزء من ATP)"
          ]
        },
        "related_terms": [
          "التوازن الغذائي",
          "نسبة K/Mg",
          "التفاعلات الأيونية"
        ],
        "field_ar": "تغذية النبات"
      },
      {
        "id": "term-016",
        "arabic": "التسميد الورقي",
        "english": "Foliar Fertilization",
        "latin": null,
        "definition_ar": "إضافة الأسمدة مذابة عبر رش الأوراق — يتجاوز عوائق التربة — فعّال للعناصر الصغرى والمغذيات في الإجهاد",
        "definition_en": "Application of dissolved fertilizers through leaf spraying — bypasses soil constraints — effective for micronutrients and nutrients under stress",
        "advantages_ar": [
          "سرعة الامتصاص 1-4 أيام",
          "يتجاوز ثبيت P وFe في التربة القلوية",
          "كميات أقل"
        ],
        "limitations_ar": [
          "لا يُغني عن التسميد الأرضي",
          "درجات حرارة عالية تحرق الأوراق",
          "تركيز أقل من 3% عموماً"
        ],
        "absorption_mechanism_ar": "امتصاص عبر الكيوتيكل الورقي أو الثغور",
        "related_terms": [
          "الكيوتيكل الورقي",
          "الثغور",
          "الفلويم"
        ],
        "field_ar": "علم الأسمدة"
      },
      {
        "id": "term-017",
        "arabic": "التسميد التنقيطي (الهيدروبونيك الأرضي)",
        "english": "Fertigation",
        "latin": null,
        "definition_ar": "إضافة الأسمدة مذابة عبر نظام الري التنقيطي مباشرة إلى منطقة الجذور — يجمع بين الري والتسميد في عملية واحدة",
        "definition_en": "Application of dissolved fertilizers through drip irrigation system directly to the root zone — combines irrigation and fertilization",
        "advantages_ar": [
          "كفاءة استخدام المياه والأسمدة 90-95%",
          "توزيع منتظم",
          "تحكم دقيق في التوقيت والكمية"
        ],
        "solubility_requirements_ar": "تستخدم فقط أسمدة عالية الذوبان: يوريا — نترات — MAP — MKP — SOP — نترات كالسيوم",
        "related_terms": [
          "EC المحلول",
          "نسبة NPK",
          "حقن السماد"
        ],
        "field_ar": "الري والصرف"
      },
      {
        "id": "term-018",
        "arabic": "الأسموبوتيكات النباتية",
        "english": "Plant Osmoprotectants / Osmolytes",
        "latin": null,
        "definition_ar": "مركبات عضوية تتراكم في خلايا النبات تحت الإجهاد (جفاف — ملوحة — برودة) لحماية البروتينات والأغشية — مثل البرولين والجليسين البيتين",
        "definition_en": "Organic compounds accumulated in plant cells under stress (drought, salinity, cold) to protect proteins and membranes — e.g., proline, glycine betaine",
        "examples_ar": [
          "البرولين (Proline)",
          "الجليسين البيتين (Glycine betaine)",
          "السكريات المذابة (Soluble sugars)"
        ],
        "agricultural_application_ar": "الأحماض الأمينية الخارجية تُحفز تكوين الأسموبوتيكات — تزيد مقاومة الإجهاد",
        "related_terms": [
          "الإجهاد المائي",
          "مقاومة الملوحة",
          "الأحماض الأمينية"
        ],
        "field_ar": "فسيولوجيا النبات"
      },
      {
        "id": "term-019",
        "arabic": "التصنيف النباتي (التاكسونومي)",
        "english": "Plant Taxonomy / Classification",
        "latin": "Taxonomia",
        "definition_ar": "علم تصنيف النباتات إلى مجموعات متدرجة: مملكة → شعبة → صف → رتبة → فصيلة → جنس → نوع",
        "definition_en": "The science of classifying plants into hierarchical groups: Kingdom → Division → Class → Order → Family → Genus → Species",
        "hierarchy_ar": {
          "kingdom_ar": "مملكة — Kingdom",
          "division_ar": "شعبة — Division / Phylum",
          "class_ar": "صف — Class",
          "order_ar": "رتبة — Order",
          "family_ar": "فصيلة — Family",
          "genus_ar": "جنس — Genus",
          "species_ar": "نوع — Species",
          "variety_ar": "صنف — Variety / Cultivar"
        },
        "naming_convention_ar": "الاسم العلمي ثنائي (Binomial) — الجنس مع أولى حروفه كبيرة + النوع بأحرف صغيرة — يُكتب مائلاً",
        "example_ar": "Triticum aestivum L. — القمح — L. = Linnaeus واضع الاسم",
        "related_terms": [
          "التسمية ثنائية",
          "الاسم العلمي",
          "الصنف المزروع"
        ],
        "field_ar": "علم النبات"
      },
      {
        "id": "term-020",
        "arabic": "مقياس التوصيل الكهربي",
        "english": "Electrical Conductivity (EC)",
        "latin": null,
        "definition_ar": "مقياس كمية الأملاح الذائبة في الماء أو التربة — يُقاس بـ dS/m أو mS/cm — EC عالية = ملوحة عالية = ضغط أسموزي عالٍ",
        "definition_en": "A measure of dissolved salts in water or soil — measured in dS/m or mS/cm — high EC = high salinity = high osmotic pressure",
        "interpretation_ar": {
          "ec_0_to_2": "أقل من 2 dS/m — غير ملح — مناسب لجميع المحاصيل",
          "ec_2_to_4": "2-4 dS/m — خفيف — يضر المحاصيل الحساسة",
          "ec_4_to_8": "4-8 dS/m — متوسط — المحاصيل المتحملة فقط",
          "ec_above_8": "أكثر من 8 dS/m — شديد — القليل جداً من المحاصيل"
        },
        "related_terms": [
          "الملوحة",
          "TDS",
          "الضغط الأسموزي"
        ],
        "field_ar": "علم التربة"
      },
      {
        "id": "term-021",
        "arabic": "المادة العضوية للتربة",
        "english": "Soil Organic Matter (SOM)",
        "latin": null,
        "definition_ar": "مجموع المواد العضوية في التربة بما فيها الكائنات الحية والمواد المتحللة (الهيوموس) — تُحسن البنية والخصوبة والحياة الميكروبية",
        "definition_en": "The total organic material in soil including living organisms and decomposed matter (humus) — improves structure, fertility, and microbial life",
        "importance_ar": [
          "ترفع CEC وتحتجز العناصر",
          "تحسن بنية التربة وتهويتها",
          "تغذي الكائنات المفيدة في التربة",
          "ترفع احتجاز الماء",
          "تُفرز أحماض تُحرر العناصر المثبتة"
        ],
        "critical_level_ar": "التربة المصرية: 0.5-1.5% (منخفض) — المستهدف: أكثر من 2%",
        "related_terms": [
          "الهيوموس",
          "الكمبوست",
          "التحلل العضوي"
        ],
        "field_ar": "علم التربة"
      },
      {
        "id": "term-022",
        "arabic": "الكيلات",
        "english": "Chelate / Chelation",
        "latin": "Chela (مخلب باللاتينية)",
        "definition_ar": "مركب عضوي يُحيط بأيون معدني ويُثبته في شكل قابل للامتصاص — يمنع ترسب العناصر الصغرى في التربة القلوية",
        "definition_en": "An organic compound that surrounds and stabilizes a metal ion in a bioavailable form — prevents micronutrient precipitation in alkaline soils",
        "common_chelates_ar": {
          "EDTA": "فعّال في pH 4-6",
          "DTPA": "فعّال في pH 4-7.5",
          "EDDHA": "فعّال حتى pH 9 — الأفضل في التربة القلوية المصرية"
        },
        "agricultural_application_ar": "كيلات الحديد (Fe-EDDHA) الأفضل لتصحيح نقص الحديد في التربة القلوية",
        "related_terms": [
          "EDTA",
          "DTPA",
          "EDDHA",
          "أيون المعدن"
        ],
        "field_ar": "الكيمياء الزراعية"
      },
