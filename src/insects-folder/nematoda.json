  "general_overview": {
    "definition_ar": "النيماتودا أو الديدان الخيطية كائنات دقيقة متعددة الخلايا تنتمي لشعبة Nematoda — معظمها لا يرى بالعين المجردة — طولها يتراوح من 0.3 مم إلى عدة سنتيمترات — تعيش في التربة والمياه وجسم المضيف",
    "size_ar": "0.1 — 5 مم (معظم الأنواع الزراعية الضارة 0.3 — 1.5 مم)",
    "shape_ar": "خيطية الشكل — أسطوانية — رفيعة للغاية — تتحرك بحركة تموجية مميزة",
